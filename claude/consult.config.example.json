{
  "_comment": "consult.config.example.json - consult.config.json のテンプレートです。コピーして consult.config.json を作成し、あなたの環境に合わせて編集してください。",

  "outRoot": "ai-consult-tools/claude/consult_case",

  "ruleFile": "ai-consult-tools/claude/00_ai_consult_operation_rules.md",

  "excludeFolders": [
    ".git",
    ".backups",
    ".vscode",
    "node_modules",
    "vendor",
    "dist",
    "build",
    "out",
    "release",
    "bk",
    "ai-consult-tools/claude/consult_case",
    "ai-consult-tools/claude/consult_project"
  ],

  "excludeExtensions": [
    ".xlsx",
    ".docx",
    ".pdf",
    ".ico",
    ".svg",
    ".webp",
    ".png",
    ".jpg",
    ".gif",
    ".psd",
    ".avif",
    ".wav",
    ".mp3",
    ".mp4",
    ".zip",
    ".rar",
    ".7z",
    ".tar",
    ".gz",
    ".map",
    ".bak",
    ".bin",
    ".log",
    ".ttf",
    ".otf",
    ".woff",
    ".woff2",
    ".exe",
    ".dll",
    ".so"
  ],

  "excludeNamePatterns": [
    "*.min.js",
    "*.min.css"
  ],

  "secretNamePatterns": [
    ".env*",
    "*.env*",
    "*secret*",
    "*secrets*.*",
    "*credential*",
    "*.pem",
    "*.key",
    "*.pfx",
    "*.p12",
    "id_rsa*",
    "*.jks",
    "*.keystore",
    "key.properties",
    "local.properties",
    "google-services.json",
    "GoogleService-Info.plist"
  ],

  "allowedToolIncludeFiles": [
    "ai-consult-tools/claude/00_ai_consult_operation_rules.md",
    "ai-consult-tools/claude/01_make_consult_bundle_spec.md",
    "ai-consult-tools/claude/02_consult_template.md",
    "ai-consult-tools/claude/03_claude_session_guide.md",
    "ai-consult-tools/claude/README_release.md",
    "ai-consult-tools/claude/SECURITY.md",
    "ai-consult-tools/claude/consult.config.json",
    "ai-consult-tools/claude/consult.config.example.json",
    "ai-consult-tools/claude/consult_bundle_claude.py"
  ]
}
